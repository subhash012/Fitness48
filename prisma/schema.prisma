generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MembershipPlan {
  id          String   @id @default(cuid())
  name        String
  duration    String
  price       Int
  highlight   Boolean  @default(false)
  benefits    String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Program {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  benefits    String[]
  duration    String
  suitableFor String
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryImage {
  id          String   @id @default(cuid())
  title       String
  category    String
  imageUrl    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Transformation {
  id            String   @id @default(cuid())
  memberName    String
  story         String
  beforeImage   String?
  afterImage    String?
  weightLostKg  Float?
  muscleGainKg  Float?
  videoUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TrialBooking {
  id                String   @id @default(cuid())
  fullName          String
  phoneNumber       String
  email             String?
  age               Int?
  gender            String?
  fitnessGoal       String
  preferredTimeSlot String
  source            String   @default("website")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ContactMessage {
  id          String   @id @default(cuid())
  fullName    String
  phoneNumber String
  email       String?
  message     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GymInformation {
  id             String   @id @default(cuid())
  name           String
  address        String
  phoneNumber    String
  email          String
  whatsappNumber String
  openingHours   String
  mapsUrl        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}